DB_HOST=localhost
DB_PORT=5434
DB_NAME=news_scraper
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSLMODE=disable

SERVER_PORT=8082
API_KEY=your_api_key_here

# CORS_ALLOWED_ORIGINS — vergüllə ayrılmış origin siyahısı, məs.
# "https://dashboard.example.com,http://localhost:3000". Boş qalsa
# (default), CORS header-ləri ümumiyyətlə əlavə olunmur (brauzerdən
# çarpaz-domen sorğu mümkün olmur). Dashboard/frontend əlavə olunanda təyin edin.
CORS_ALLOWED_ORIGINS=

# RATE_LIMIT_PER_MINUTE / RATE_LIMIT_BURST — IP başına dəqiqədə icazə
# verilən sorğu sayı (token bucket). RATE_LIMIT_PER_MINUTE=0 tamamilə
# deaktiv edir. Boş qalsa default 300/50 istifadə olunur.
RATE_LIMIT_PER_MINUTE=300
RATE_LIMIT_BURST=50

# DB_MAX_CONNS — pgxpool-un maksimum connection sayı. Boş qalsa pgx-in öz
# default-u (CPU sayına bağlı) istifadə olunur. WORKER_COUNT-u artırsan,
# bunu da (məs. WORKER_COUNT + 5) artırmaq faydalı ola bilər.
DB_MAX_CONNS=

LOG_LEVEL=debug
LOG_FORMAT=pretty

POLL_INTERVAL_SECONDS=900
WORKER_COUNT=5

PLAYWRIGHT_HEADLESS=false